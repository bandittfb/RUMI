{
  "name": "rumi",
  "version": "1.0.0",
  "description": "RUMI — Revealed Uncollapsed Manifold Instrument. A local-first instrument for discovering latent affordances at the intersection of correction pressure, code capacity, and utilization.",
  "type": "module",
  "bin": {
    "rumi": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "rumi": "node dist/index.js",
    "scan": "node dist/index.js scan --repo examples/sample-repo --data examples/data",
    "discover": "node dist/index.js discover --repo examples/sample-repo --data examples/data",
    "reflect": "node dist/index.js reflect --repo examples/sample-repo --data examples/data",
    "dashboard": "node dist/index.js dashboard --repo examples/sample-repo --data examples/data",
    "baseline": "node dist/index.js experiment baseline --data examples/data",
    "clean": "rm -rf dist .rumi"
  },
  "keywords": [
    "displacement",
    "latent-affordance",
    "correction-field",
    "instrument",
    "collapse-potential",
    "rectifier-seed"
  ],
  "author": "Frank Brannen",
  "license": "UNLICENSED",
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.5.0",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
